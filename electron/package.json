{
  "name": "simdragosa-standalone",
  "version": "0.1.0",
  "description": "Standalone Windows desktop app for Simdragosa",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "jest",
    "build": "electron-builder --config electron-builder.yml",
    "build:dir": "electron-builder --config electron-builder.yml --dir",
    "publish": "electron-builder --config electron-builder.yml --publish always"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "jest": "^30.3.0"
  },
  "overrides": {
    "glob": "^13.0.6"
  }
}
